{
  "name": "pare",
  "version": "0.3.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "gen:blog": "node scripts/gen-blog-content.mjs",
    "build": "npm run gen:blog && next build",
    "start": "next start",
    "lint": "eslint",
    "guard": "node scripts/check-no-private.mjs",
    "gen:migrations": "tsx scripts/gen-migrations.ts",
    "gen:demo": "tsx scripts/seed-demo.ts && PARE_DB_PATH=data/demo.db tsx scripts/gen-demo-json.ts",
    "test": "python3 -m unittest discover -s tests",
    "test:e2e": "playwright test",
    "test:repo": "PARE_DATA_DIR=$(mktemp -d) PARE_DB_PATH=$(mktemp -d)/pare-test.db tsx --test lib/*.test.ts lib/repo/*.test.ts lib/parser/*.test.ts lib/storage/*.test.ts lib/queue/*.test.ts cloud/billing/*.test.ts lib/import/*.test.ts lib/simplefin/*.test.ts mcp/*.test.ts",
    "test:do-sql": "vitest run --config vitest.workers.config.ts",
    "test:auth": "tsx --test lib/auth/*.test.ts",
    "test:cloud": "tsx --test cloud/ingest/*.test.ts",
    "typecheck:workers": "tsc --noEmit -p tsconfig.workers.json",
    "mcp": "tsx mcp/server.ts",
    "cf:build": "opennextjs-cloudflare build",
    "cf:preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "cf:deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf:typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@better-auth/passkey": "^1.6.18",
    "@cloudflare/containers": "^0.3.7",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@sentry/cloudflare": "^10.57.0",
    "better-auth": "^1.6.18",
    "better-sqlite3": "^12.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gray-matter": "^4.0.3",
    "kysely-d1": "^0.4.0",
    "lucide-react": "^1.17.0",
    "marked": "^18.0.5",
    "next": "16.2.7",
    "next-themes": "^0.4.6",
    "postal-mime": "^2.7.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "resend": "^6.12.4",
    "shadcn": "^4.10.0",
    "stripe": "^22.2.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.8.71",
    "@cloudflare/workers-types": "^4.20260613.1",
    "@opennextjs/cloudflare": "^1.19.11",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "miniflare": "^4.20260611.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^3.2.6",
    "wrangler": "^4.100.0"
  }
}
