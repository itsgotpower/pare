# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# cloudflare / opennext build output
/.open-next/
.wrangler/
cloudflare-env.d.ts

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# financial data — NEVER commit
data/
*.db
*.pdf
transactions.csv
*.xlsx
*.xls
report.html

# local agent config (absolute machine paths)
.claude/

# throwaway local R&D / scratch experiments (e.g. encryption spikes)
spike/

# private / never-publish — this is the PUBLIC open-core repo.
# (enforced by scripts/check-no-private.mjs + .github/workflows/guard-private.yml)
# NOTE: gitignore has no inline comments — keep patterns on their own lines.
# internal/ = business docs (PRD/SRS/pricing/strategy)
# SETUP.md = two-repo dev-workflow doc
# docs/encryption-design.md = internal design draft
internal/
SETUP.md
docs/encryption-design.md
